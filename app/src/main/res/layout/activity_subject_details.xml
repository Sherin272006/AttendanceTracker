<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:paddingTop="50dp">

        <!-- Subject Title -->

        <TextView
            android:id="@+id/tvSubjectTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subject"
            android:textColor="#BB86FC"
            android:textStyle="bold"
            android:textSize="30sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track your attendance in real time."
            android:textColor="#BDBDBD"
            android:textSize="15sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp"/>

        <!-- Attendance Card -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="170dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Attendance"
                    android:textColor="#BDBDBD"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvAttendancePercentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#BB86FC"
                    android:textStyle="bold"
                    android:textSize="50sp"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Statistics Card -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="5dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvPresent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Present Classes : 0"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"/>

                <TextView
                    android:id="@+id/tvConducted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conducted Classes : 0"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:layout_marginTop="14dp"/>

                <TextView
                    android:id="@+id/tvMinimumAttendance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minimum Attendance : 75%"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:layout_marginTop="14dp"/>

                <TextView
                    android:id="@+id/tvSkippableClasses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You can skip 0 classes."
                    android:textColor="#BB86FC"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginTop="16dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Buttons -->

        <Button
            android:id="@+id/btnPresent"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/rounded_button"
            android:text="Present"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="17sp"/>

        <Button
            android:id="@+id/btnAbsent"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/rounded_button"
            android:text="Absent"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="17sp"/>

    </LinearLayout>

</ScrollView>