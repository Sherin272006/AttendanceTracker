<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Subject Name -->

        <TextView
            android:id="@+id/tvSubjectTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subject"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track your attendance effortlessly."
            android:textColor="#BDBDBD"
            android:textSize="15sp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="20dp"/>

        <!-- Attendance Card -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="170dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Attendance"
                    android:textColor="#BBBBBB"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvAttendancePercentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="87%"
                    android:textColor="#BB86FC"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tvAttendanceStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟢 Excellent Attendance"
                    android:textColor="#4CAF50"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Details Card -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvPresent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Present Classes : 0"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"/>

                <TextView
                    android:id="@+id/tvConducted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conducted Classes : 0"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:id="@+id/tvMinimumAttendance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minimum Attendance : 75%"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:id="@+id/tvSkippableClasses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You can skip 0 classes."
                    android:textColor="#BB86FC"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:layout_marginTop="18dp"/>

                <TextView
                    android:id="@+id/tvNeedToAttend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚 Attend next 0 classes to reach minimum attendance."
                    android:textColor="#03DAC5"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Buttons -->

        <Button
            android:id="@+id/btnPresent"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="28dp"
            android:text="✓ Present"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:backgroundTint="#4CAF50"/>

        <Button
            android:id="@+id/btnAbsent"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="14dp"
            android:text="✗ Absent"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:backgroundTint="#F44336"/>

        <Button
            android:id="@+id/btnCalendar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="14dp"
            android:text="📅 Attendance Calendar"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:background="@drawable/rounded_button"/>

        <Button
            android:id="@+id/btnDeleteSubject"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="14dp"
            android:text="🗑 Delete Subject"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:backgroundTint="#E53935"/>

        <Button
            android:id="@+id/btnResetAttendance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset Attendance"
            android:layout_marginTop="16dp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</ScrollView>